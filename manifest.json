{
  "manifest_version": 3,
  "name": "CF StatLens",
  "version": "1.0.0",
  "description": "Hover over your Codeforces activity heatmap to see daily submissions, accepted count, accuracy percentage, and deep analytics.",
  
  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "*://codeforces.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://codeforces.com/profile/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "CF StatLens"
  }
}
